@page "/"
@rendermode InteractiveServer
@inject ChannelService ChannelService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Channels – Vod2Tube</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h5">
        <MudIcon Icon="@Icons.Material.Filled.Tv" Class="mr-2" Style="vertical-align:middle" />
        Twitch Channels
    </MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
        OnClick="OpenAddDialog">
        Add Channel
    </MudButton>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}

<MudTable Items="_channels" Hover="true" Striped="true" Loading="_loading"
    LoadingProgressColor="Color.Primary" Elevation="2">
    <HeaderContent>
        <MudTh>Channel</MudTh>
        <MudTh>Status</MudTh>
        <MudTh>Added</MudTh>
        <MudTh Style="text-align:right">Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudAvatar Color="Color.Primary" Size="Size.Small">
                    @(context.ChannelName.Length > 0 ? char.ToUpper(context.ChannelName[0]) : '?')
                </MudAvatar>
                <MudLink Href="@($"https://www.twitch.tv/{context.ChannelName}")" Target="_blank">
                    @context.ChannelName
                </MudLink>
            </MudStack>
        </MudTd>
        <MudTd>
            <MudChip T="string" Color="@(context.Active ? Color.Success : Color.Warning)"
                Size="Size.Small" Variant="Variant.Filled">
                @(context.Active ? "Active" : "Paused")
            </MudChip>
            @if (!string.IsNullOrWhiteSpace(context.CurrentVodId))
            {
                <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1">
                    Processing oldest queued VOD: @(context.CurrentVodTitle ?? context.CurrentVodId)
                </MudText>
            }
        </MudTd>
        <MudTd>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                @context.AddedAtUTC.ToLocalTime().ToString("MMM dd, yyyy")
            </MudText>
        </MudTd>
        <MudTd Style="text-align:right">
            <MudTooltip Text="@(context.Active ? "Pause channel" : "Activate channel")">
                <MudIconButton Icon="@(context.Active ? Icons.Material.Filled.Pause : Icons.Material.Filled.PlayArrow)"
                    Color="@(context.Active ? Color.Warning : Color.Success)"
                    Size="Size.Small"
                    OnClick="@(() => ToggleActiveAsync(context))" />
            </MudTooltip>
            <MudTooltip Text="Edit">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Default" Size="Size.Small"
                    OnClick="@(() => OpenEditDialog(context))" />
            </MudTooltip>
            <MudTooltip Text="Delete">
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                    OnClick="@(() => DeleteChannelAsync(context))" />
            </MudTooltip>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText Class="py-8 mud-text-secondary" Align="Align.Center">
            No channels added yet. Click <strong>Add Channel</strong> to get started.
        </MudText>
    </NoRecordsContent>
</MudTable>

<!-- Add/Edit Dialog -->
<MudDialog @bind-Visible="_dialogVisible" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(_editingChannel?.Id == 0 ? Icons.Material.Filled.Add : Icons.Material.Filled.Edit)"
                Class="mr-1" Style="vertical-align:middle" />
            @(_editingChannel?.Id == 0 ? "Add Channel" : "Edit Channel")
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_editingChannel != null)
        {
            <MudTextField @bind-Value="_editingChannel.ChannelName"
                Label="Twitch Channel Name"
                Placeholder="e.g. shroud"
                Immediate="true"
                Variant="Variant.Outlined"
                Required="true"
                Adornment="Adornment.Start"
                AdornmentIcon="@Icons.Material.Filled.Tv"
                Class="mb-2" />
            <MudSwitch @bind-Value="_editingChannel.Active" Color="Color.Success" Label="Active (monitor for new VODs)" />
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDialog">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveChannelAsync"
            Disabled="@(string.IsNullOrWhiteSpace(_editingChannel?.ChannelName))">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<Channel> _channels = new();
    private bool _loading = true;
    private bool _dialogVisible = false;
    private Channel? _editingChannel;

    private DialogOptions _dialogOptions = new()
    {
        MaxWidth = MaxWidth.Small,
        FullWidth = true,
        CloseOnEscapeKey = true
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadChannelsAsync();
    }

    private async Task LoadChannelsAsync()
    {
        _loading = true;
        _channels = await ChannelService.GetAllChannelsAsync();
        _loading = false;
    }

    private void OpenAddDialog()
    {
        _editingChannel = new Channel { Active = true };
        _dialogVisible = true;
    }

    private void OpenEditDialog(Channel channel)
    {
        _editingChannel = new Channel
        {
            Id = channel.Id,
            ChannelName = channel.ChannelName,
            Active = channel.Active,
            AddedAtUTC = channel.AddedAtUTC
        };
        _dialogVisible = true;
    }

    private void CloseDialog()
    {
        _dialogVisible = false;
        _editingChannel = null;
    }

    private async Task SaveChannelAsync()
    {
        if (_editingChannel == null) return;

        if (_editingChannel.Id == 0)
        {
            await ChannelService.AddNewChannelAsync(_editingChannel);
            Snackbar.Add($"Channel '{_editingChannel.ChannelName}' added.", Severity.Success);
        }
        else
        {
            await ChannelService.UpdateChannelAsync(_editingChannel);
            Snackbar.Add($"Channel '{_editingChannel.ChannelName}' updated.", Severity.Success);
        }

        CloseDialog();
        await LoadChannelsAsync();
    }

    private async Task ToggleActiveAsync(Channel channel)
    {
        channel.Active = !channel.Active;
        await ChannelService.UpdateChannelAsync(channel);
        Snackbar.Add($"Channel '{channel.ChannelName}' {(channel.Active ? "activated" : "paused")}.", Severity.Info);
        await LoadChannelsAsync();
    }

    private async Task DeleteChannelAsync(Channel channel)
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Delete Channel",
            $"Are you sure you want to delete '{channel.ChannelName}'? This will not remove existing pipeline jobs.",
            yesText: "Delete", cancelText: "Cancel");

        if (confirmed == true)
        {
            await ChannelService.DeleteChannelAsync(channel.Id);
            Snackbar.Add($"Channel '{channel.ChannelName}' deleted.", Severity.Warning);
            await LoadChannelsAsync();
        }
    }
}
