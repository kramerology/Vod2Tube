@page "/completed"
@rendermode InteractiveServer
@inject PipelineService PipelineService
@inject ISnackbar Snackbar

<PageTitle>Completed Jobs – Vod2Tube</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h5">
        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Class="mr-2" Style="vertical-align:middle" />
        Completed Jobs
    </MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.Refresh"
        OnClick="LoadJobsAsync">
        Refresh
    </MudButton>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}

<MudTable Items="_jobs" Hover="true" Striped="true" Dense="false" Loading="_loading"
    LoadingProgressColor="Color.Primary" Elevation="2"
    Filter="@(new Func<PipelineJobDto, bool>(FilterJobs))">
    <ToolBarContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Style="width:100%">
            <MudChip T="string" Color="Color.Success" Size="Size.Small"
                Icon="@Icons.Material.Filled.CheckCircle">
                @_jobs.Count(j => j.Stage == "Uploaded") Uploaded
            </MudChip>
            <MudChip T="string" Color="Color.Default" Size="Size.Small"
                Icon="@Icons.Material.Filled.Cancel">
                @_jobs.Count(j => j.Stage == "Cancelled") Cancelled
            </MudChip>
            <MudSpacer />
            <MudTextField @bind-Value="_searchText" Placeholder="Search..." Adornment="Adornment.Start"
                AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium"
                Variant="Variant.Outlined" Margin="Margin.Dense" Class="search-field" />
        </MudStack>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>VOD</MudTh>
        <MudTh>Channel</MudTh>
        <MudTh>Duration</MudTh>
        <MudTh>Status</MudTh>
        <MudTh>YouTube</MudTh>
        <MudTh Style="text-align:right">Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>
            <MudText Typo="Typo.subtitle2">@context.Title</MudText>
            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                @(context.CreatedAtUTC != DateTime.MinValue
                    ? context.CreatedAtUTC.ToLocalTime().ToString("MMM dd, yyyy")
                    : context.VodId)
            </MudText>
        </MudTd>
        <MudTd>
            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.Tv" Size="Size.Small" Color="Color.Secondary" />
                <MudText Typo="Typo.body2">@context.ChannelName</MudText>
            </MudStack>
        </MudTd>
        <MudTd>
            <MudText Typo="Typo.body2">@FormatDuration(context.Duration)</MudText>
        </MudTd>
        <MudTd>
            <MudChip T="string"
                Color="@(context.Stage == "Uploaded" ? Color.Success : Color.Default)"
                Size="Size.Small"
                Variant="Variant.Filled"
                Icon="@(context.Stage == "Uploaded" ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)">
                @(context.Stage == "Uploaded" ? "Uploaded" : "Cancelled")
            </MudChip>
        </MudTd>
        <MudTd>
            @if (!string.IsNullOrEmpty(context.YoutubeVideoId))
            {
                <MudLink Href="@($"https://www.youtube.com/watch?v={context.YoutubeVideoId}")"
                    Target="_blank" Color="Color.Error">
                    <MudIcon Icon="@Icons.Material.Filled.PlayCircle" Size="Size.Small" Class="mr-1" />
                    Watch
                </MudLink>
            }
            else
            {
                <MudText Typo="Typo.body2" Class="mud-text-disabled">—</MudText>
            }
        </MudTd>
        <MudTd Style="text-align:right">
            @if (context.Stage == "Cancelled")
            {
                <MudTooltip Text="Re-queue this VOD for processing">
                    <MudIconButton Icon="@Icons.Material.Filled.Replay" Color="Color.Primary" Size="Size.Small"
                        OnClick="@(() => RetryJobAsync(context))" />
                </MudTooltip>
            }
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText Class="py-8 mud-text-secondary" Align="Align.Center">
            No completed jobs yet.
        </MudText>
    </NoRecordsContent>
</MudTable>

@code {
    private List<PipelineJobDto> _jobs = new();
    private bool _loading = true;
    private string _searchText = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadJobsAsync();
    }

    private async Task LoadJobsAsync()
    {
        _loading = true;
        _jobs = await PipelineService.GetCompletedJobsAsync();
        _loading = false;
    }

    private bool FilterJobs(PipelineJobDto job)
    {
        if (string.IsNullOrWhiteSpace(_searchText)) return true;
        var search = _searchText.Trim();
        return job.Title.Contains(search, StringComparison.OrdinalIgnoreCase)
            || job.ChannelName.Contains(search, StringComparison.OrdinalIgnoreCase)
            || job.VodId.Contains(search, StringComparison.OrdinalIgnoreCase);
    }

    private async Task RetryJobAsync(PipelineJobDto job)
    {
        await PipelineService.RetryJobAsync(job.VodId);
        Snackbar.Add($"'{job.Title}' re-queued for processing.", Severity.Info);
        await LoadJobsAsync();
    }

    private static string FormatDuration(TimeSpan ts)
    {
        if (ts == TimeSpan.Zero) return "—";
        if (ts.TotalHours >= 1)
            return $"{(int)ts.TotalHours}h {ts.Minutes}m";
        return $"{ts.Minutes}m {ts.Seconds}s";
    }
}
